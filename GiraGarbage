cls

$JiraInstance = @('Microsoft', 'Apple')
$AllIssues = @()
$JiraBaseUrl = [string]::Empty
$JqlQuery = [string]::Empty

$JiraApiToken = ""
$JiraEmail = "bill.gates@microsoft.com"

foreach ($Instance in $JiraInstance) {

    switch ($Instance) {
        'Microsoft' {
            $JiraBaseUrl = 'https://microsoft.atlassian.net/'
            $JqlQuery = 'labels in (Security) and (type = Security or type = Bug) and createdDate >= "2026-02-01" and createdDate <= "2026-02-28" and priority = Highest'
        }
        'Apple' {
            $JiraBaseUrl = 'https://apple.atlassian.net/'
            $JqlQuery = 'labels in (Security) and type = Bug and createdDate >= "2026-02-01" and createdDate <= "2026-02-28" and priority = Highest'
        }
    }

    $Headers = @{ 
        Authorization = "Basic " + [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes("$($JiraEmail):$($JiraApiToken)"))
        Accept        = "application/json"
    }

    $nextPageToken = $null

    do {
        if ($nextPageToken) {   
            $ApiUrl = "$JiraBaseUrl/rest/api/3/search/jql?jql=$([uri]::EscapeDataString($JqlQuery))&maxResults=100&fields=priority,created,summary&nextPageToken=$nextPageToken"
        }
        else {
            $ApiUrl = "$JiraBaseUrl/rest/api/3/search/jql?jql=$([uri]::EscapeDataString($JqlQuery))&maxResults=100&fields=priority,created,summary"
        }
        $Response = Invoke-RestMethod -Uri $ApiUrl -Headers $Headers -Method Get
        $AppIssues += $Response.issues
        $nextPageToken = $Response.nextPageToken
        Write-Output "$App Fetched $($AppIssues.Count) issues"
        $AllIssues += [PSCustomObject]@{
            Status       = $Issue.fields.status.name
            CreatedDate  = $FormattedCreatedDate
            ResolvedDate = $Issue.fields.status.ResolvedDate
        }
    } while ($null -ne $nextPageToken)
}

