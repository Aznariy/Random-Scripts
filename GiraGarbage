cls

$JiraInstance = @("Microsoft", "Google")
$AllIssues = @()
$JiraBaseUrl = [string]::Empty
$JqlQuery = [string]::Empty
$startMonth = "2026-02-01"
$endMonth = "2026-02-28"

$JiraApiToken = ""
$JiraEmail = ""

foreach ($Instance in $JiraInstance) {

    switch ($Instance) {
        "Microsoft" {
            $JiraBaseUrl = "https://microsoft.atlassian.net/"
            $JqlQuery = "labels in (Security) and (type = Security or type = Bug) and createdDate >= $($startMonth) and createdDate <= $($endMonth) and priority = High and status = Done"
        }
        "Google" {
            $JiraBaseUrl = "https://google-jira.atlassian.net/"
            $JqlQuery = "labels in (Security) and type = Bug and createdDate >= $($startMonth) and createdDate <= $($endMonth) and (priority = High or priority = 'High (migrated)') and status = Done"
        }
    }

    $Headers = @{ 
        Authorization = "Basic " + [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes("$($JiraEmail):$($JiraApiToken)"))
        Accept        = "application/json"
    }

    $nextPageToken = $null

    do {
        if ($nextPageToken) {   
            $ApiUrl = "$JiraBaseUrl/rest/api/3/search/jql?jql=$([uri]::EscapeDataString($JqlQuery))&maxResults=100&fields=priority,created,status,resolutiondate&nextPageToken=$nextPageToken"
        }
        else {
            $ApiUrl = "$JiraBaseUrl/rest/api/3/search/jql?jql=$([uri]::EscapeDataString($JqlQuery))&maxResults=100&fields=priority,created,status,resolutiondate"
        }
        $Response = Invoke-RestMethod -Uri $ApiUrl -Headers $Headers -Method Get
        $AppIssues = $Response.issues
        $nextPageToken = $Response.nextPageToken
        Write-Output "$Instance Fetched $($AppIssues.Count) issues"
        foreach ($Issue in $AppIssues) {
                $AllIssues += [PSCustomObject]@{
                    Status       = $Issue.fields.status.name
                    CreatedDate  = ([datetime]$Issue.fields.created).ToString("yyyy-MM-dd")
                    ResolvedDate = ([datetime]$Issue.fields.resolutiondate).ToString("yyyy-MM-dd")
                }
            }

    } while ($null -ne $nextPageToken)
}

$results = $AllIssues | ForEach-Object {

    $days = ([datetime]$_.ResolvedDate - [datetime]$_.CreatedDate).Days

    [PSCustomObject]@{
        DaysToRemediate = $days
    }
}

$average = ($results | Measure-Object -Property DaysToRemediate -Average).Average

Write-Host "Average time to remediate: $average days"
